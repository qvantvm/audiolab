{
  "schema_version": "0.1",
  "name": "membrane_impact_representation",
  "description": "Representation-only drum impact to circular membrane modal bank. Validates but compile fails until membrane_shell_modal solver exists.",
  "sample_rate": 48000,
  "duration": 1.0,
  "block_size": 64,
  "inputs": {},
  "blocks": [
    {
      "id": "mallet",
      "type": "NoiseBurst",
      "params": {"amplitude": 1.0, "decay_ms": 2.0, "seed": 2}
    },
    {
      "id": "impact",
      "type": "ImpactContact",
      "params": {}
    },
    {
      "id": "membrane",
      "type": "CircularMembraneModes",
      "params": {
        "radius_m": 0.18,
        "tension_n_per_m": 3000.0,
        "num_modes": 16
      }
    },
    {
      "id": "out",
      "type": "Output",
      "params": {}
    }
  ],
  "connections": [
    {"from": "mallet.audio", "to": "impact.mallet_velocity"},
    {"from": "impact.surface_velocity", "to": "membrane.surface"},
    {"from": "membrane.radiated_audio", "to": "out.audio"}
  ],
  "probes": ["membrane.radiated_audio"],
  "ui": {
    "nodes": {
      "impact": {"x": 200, "y": 160},
      "membrane": {"x": 400, "y": 160},
      "out": {"x": 600, "y": 160}
    }
  }
}
