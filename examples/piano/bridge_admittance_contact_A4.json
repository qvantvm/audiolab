{
  "schema_version": "0.1",
  "name": "bridge_admittance_contact_A4",
  "description": "Hosted nonlinear hammer-string contact with bridge admittance/loading diagnostics.",
  "sample_rate": 48000,
  "duration": 0.35,
  "block_size": 64,
  "inputs": {
    "midi_note": 69,
    "velocity": 88
  },
  "blocks": [
    {"id": "note_freq", "type": "MidiToFrequency", "params": {"a4": 440.0}},
    {
      "id": "note",
      "type": "PASPBidirectionalHammerString",
      "params": {
        "contact_model": "bidirectional",
        "num_modes": 10,
        "oversample": 1,
        "inharmonicity_B": 0.00035,
        "velocity_scale": 3.0,
        "velocity_exponent": 1.9,
        "hammer_rest_position_m": 0.008,
        "bridge_impedance": 4200.0,
        "bridge_loss_low": 0.2,
        "bridge_loss_high": 0.35,
        "body_mix": 0.5
      }
    },
    {"id": "out", "type": "Output", "params": {"peak_normalize_db": -1.0}}
  ],
  "connections": [
    {"from": "inputs.midi_note", "to": "note_freq.midi_note"},
    {"from": "inputs.midi_note", "to": "note.midi_note"},
    {"from": "inputs.velocity", "to": "note.velocity"},
    {"from": "note_freq.frequency", "to": "note.frequency"},
    {"from": "note.audio", "to": "out.audio"}
  ],
  "probes": ["note.force", "note.bridge_audio", "out.audio"],
  "ui": {
    "nodes": {
      "note_freq": {"x": 80, "y": 90},
      "note": {"x": 360, "y": 160},
      "out": {"x": 720, "y": 160}
    }
  }
}
