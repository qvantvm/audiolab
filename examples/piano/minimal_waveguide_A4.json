{
  "schema_version": "0.1",
  "name": "minimal_waveguide_A4",
  "description": "Minimal excited waveguide string note at A4 (440 Hz) rendered through ExcitedWaveguideStringSolver.",
  "sample_rate": 48000,
  "duration": 2.0,
  "block_size": 64,
  "inputs": {
    "frequency_hz": 440.0
  },
  "blocks": [
    {
      "id": "excitation",
      "type": "NoiseBurst",
      "params": {
        "amplitude": 0.8,
        "decay_ms": 3.0,
        "seed": 0
      }
    },
    {
      "id": "string",
      "type": "String1D",
      "params": {
        "decay_seconds": 4.0,
        "brightness": 0.55,
        "gain": 1.0,
        "frequency_hz": 440.0,
        "inharmonicity_B": 0.0001
      }
    },
    {
      "id": "out",
      "type": "Output",
      "params": {
        "peak_normalize_db": -1.0
      }
    }
  ],
  "connections": [
    {"from": "excitation.audio", "to": "string.excitation"},
    {"from": "inputs.frequency_hz", "to": "string.frequency"},
    {"from": "string.audio", "to": "out.audio"}
  ],
  "probes": [
    "excitation.audio",
    "string.audio",
    "out.audio"
  ],
  "ui": {
    "nodes": {
      "excitation": {"x": 80, "y": 160},
      "string": {"x": 360, "y": 160},
      "out": {"x": 640, "y": 160}
    }
  }
}
