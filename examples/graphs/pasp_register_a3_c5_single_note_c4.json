{
  "schema_version": "0.1",
  "name": "pasp_register_a3_c5_single_note_c4",
  "sample_rate": 48000,
  "duration": 1.5,
  "block_size": 64,
  "inputs": {"midi_note": 60, "velocity_norm": 0.5},
  "blocks": [
    {"id": "note", "type": "PASPNoteFamilyModel", "params": {"contact_model": "bidirectional", "num_modes": 32, "use_register_defaults": true}},
    {"id": "out", "type": "Output", "params": {"peak_normalize_db": -1.0}}
  ],
  "connections": [
    {"from": "inputs.midi_note", "to": "note.midi_note"},
    {"from": "inputs.velocity_norm", "to": "note.velocity_norm"},
    {"from": "inputs.velocity_norm", "to": "note.velocity"},
    {"from": "note.audio", "to": "out.audio"}
  ],
  "probes": ["note.force", "note.audio", "note.bridge_audio", "out.audio"]
}
