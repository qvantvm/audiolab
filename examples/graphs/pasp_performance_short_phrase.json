          {"time_s": 0.3, "type": "note_on", "note": 60, "velocity_norm": 0.58},
          {"time_s": 0.55, "type": "pedal_down", "pedal": "sustain"},
          {"time_s": 0.7, "type": "note_on", "note": 64, "velocity_norm": 0.52},
          {"time_s": 1.0, "type": "note_off", "note": 57},
          {"time_s": 1.2, "type": "note_on", "note": 60, "velocity_norm": 0.5},
          {"time_s": 1.8, "type": "note_off", "note": 60},
          {"time_s": 2.0, "type": "note_off", "note": 64},
          {"time_s": 2.8, "type": "pedal_up", "pedal": "sustain"}
        ]
      }
    },
    {"id": "out", "type": "Output", "params": {"peak_normalize_db": -1.0}}
