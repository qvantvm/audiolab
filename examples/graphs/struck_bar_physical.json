{
  "schema_version": "0.1",
  "name": "struck_bar_physical",
  "sample_rate": 48000,
  "duration": 3.0,
  "block_size": 64,
  "inputs": {
    "midi_note": 72
  },
  "blocks": [
    {
      "id": "note_freq",
      "type": "MidiToFrequency",
      "params": {
        "a4": 440.0
      }
    },
    {
      "id": "strike",
      "type": "NoiseBurst",
      "params": {
        "amplitude": 0.85,
        "decay_ms": 3.5,
        "seed": 7
      }
    },
    {
      "id": "bar",
      "type": "StruckBarBody",
      "params": {
        "profile": "xylophone",
        "strike_position": 0.27,
        "strike_hardness": 0.64,
        "material_damping": 0.32,
        "decay_scale": 1.0,
        "resonator_mix": 0.82,
        "output_gain": 0.85
      }
    },
    {
      "id": "out",
      "type": "Output",
      "params": {
        "peak_normalize_db": -1.0
      }
    }
  ],
  "connections": [
    {
      "from": "inputs.midi_note",
      "to": "note_freq.midi_note"
    },
    {
      "from": "note_freq.frequency",
      "to": "bar.frequency"
    },
    {
      "from": "strike.audio",
      "to": "bar.excitation"
    },
    {
      "from": "bar.audio",
      "to": "out.audio"
    }
  ],
  "probes": [
    "strike.audio",
    "bar.audio",
    "out.audio"
  ],
  "ui": {
    "nodes": {
      "note_freq": {"x": 80, "y": 80},
      "strike": {"x": 80, "y": 220},
      "bar": {"x": 380, "y": 140},
      "out": {"x": 700, "y": 140}
    }
  }
}
