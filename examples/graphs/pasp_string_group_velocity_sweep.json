{
  "schema_version": "0.1",
  "name": "pasp_string_group_velocity_sweep",
  "sample_rate": 48000,
  "duration": 1.5,
  "block_size": 64,
  "inputs": {"midi_note": 60, "velocity_norm": 0.5},
  "blocks": [
    {
      "id": "panel",
      "type": "PanelMetricsTask",
      "params": {
        "panel": [
          {"midi_note": 60, "velocity_norm": 0.2},
          {"midi_note": 60, "velocity_norm": 0.35},
          {"midi_note": 60, "velocity_norm": 0.5},
          {"midi_note": 60, "velocity_norm": 0.65},
          {"midi_note": 60, "velocity_norm": 0.8}
        ]
      }
    },
    {"id": "note", "type": "PASPStringGroupNoteModel", "params": {"contact_model": "bidirectional", "num_modes": 32}},
    {"id": "out", "type": "Output", "params": {"peak_normalize_db": -1.0}}
  ],
  "connections": [
    {"from": "inputs.midi_note", "to": "note.midi_note"},
    {"from": "inputs.velocity_norm", "to": "note.velocity_norm"},
    {"from": "inputs.velocity_norm", "to": "note.velocity"},
    {"from": "note.audio", "to": "out.audio"}
  ],
  "probes": ["note.force", "note.audio", "note.bridge_audio"]
}
