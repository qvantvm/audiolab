{
  "schema_version": "0.1",
  "name": "pasp_lifecycle_two_note_pedal",
  "sample_rate": 48000,
  "duration": 3.0,
  "block_size": 64,
  "inputs": {},
  "blocks": [
    {
      "id": "piano",
      "type": "PASPEventPianoModel",
      "params": {
        "contact_model": "bidirectional",
        "num_modes": 32,
        "use_register_defaults": true,
        "events": [
          {"time_s": 0.0, "type": "note_on", "note": 60, "velocity_norm": 0.5},
          {"time_s": 0.3, "type": "note_on", "note": 64, "velocity_norm": 0.45},
          {"time_s": 0.5, "type": "pedal_down", "pedal": "sustain"},
          {"time_s": 1.2, "type": "note_off", "note": 60},
          {"time_s": 1.5, "type": "note_off", "note": 64},
          {"time_s": 2.5, "type": "pedal_up", "pedal": "sustain"}
        ]
      }
    },
    {"id": "out", "type": "Output", "params": {"peak_normalize_db": -1.0}}
  ],
  "connections": [
    {"from": "piano.audio", "to": "out.audio"}
  ],
  "probes": ["piano.audio"]
}
