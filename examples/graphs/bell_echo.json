{
  "schema_version": "0.1",
  "name": "bell_echo",
  "sample_rate": 48000,
  "duration": 5.0,
  "block_size": 64,
  "inputs": {
    "midi_note": 76
  },
  "blocks": [
    {
      "id": "note_freq",
      "type": "MidiToFrequency",
      "params": {
        "a4": 440.0
      }
    },
    {
      "id": "strike",
      "type": "NoiseBurst",
      "params": {
        "amplitude": 0.85,
        "decay_ms": 6.0,
        "seed": 42
      }
    },
    {
      "id": "bell",
      "type": "ModalResonatorBank",
      "params": {
        "partials": [
          {"ratio": 0.56, "amplitude": 0.35, "decay_seconds": 4.0},
          {"ratio": 1.0, "amplitude": 1.0, "decay_seconds": 3.2},
          {"ratio": 1.41, "amplitude": 0.55, "decay_seconds": 2.4},
          {"ratio": 2.0, "amplitude": 0.4, "decay_seconds": 1.8},
          {"ratio": 2.65, "amplitude": 0.3, "decay_seconds": 1.3},
          {"ratio": 3.0, "amplitude": 0.22, "decay_seconds": 1.0},
          {"ratio": 4.1, "amplitude": 0.15, "decay_seconds": 0.7},
          {"ratio": 5.4, "amplitude": 0.1, "decay_seconds": 0.45}
        ]
      }
    },
    {
      "id": "echo1_delay",
      "type": "Delay",
      "params": {
        "delay_ms": 320.0
      }
    },
    {
      "id": "echo1_gain",
      "type": "Gain",
      "params": {
        "gain_db": -6.0
      }
    },
    {
      "id": "echo2_delay",
      "type": "Delay",
      "params": {
        "delay_ms": 640.0
      }
    },
    {
      "id": "echo2_gain",
      "type": "Gain",
      "params": {
        "gain_db": -10.5
      }
    },
    {
      "id": "echo3_delay",
      "type": "Delay",
      "params": {
        "delay_ms": 960.0
      }
    },
    {
      "id": "echo3_gain",
      "type": "Gain",
      "params": {
        "gain_db": -14.0
      }
    },
    {
      "id": "mix",
      "type": "Mixer",
      "params": {
        "gain_db": 0.0
      }
    },
    {
      "id": "out",
      "type": "Output",
      "params": {
        "peak_normalize_db": -1.0
      }
    }
  ],
  "connections": [
    {
      "from": "inputs.midi_note",
      "to": "note_freq.midi_note"
    },
    {
      "from": "note_freq.frequency",
      "to": "bell.frequency"
    },
    {
      "from": "strike.audio",
      "to": "bell.excitation"
    },
    {
      "from": "bell.audio",
      "to": "mix.audio1"
    },
    {
      "from": "bell.audio",
      "to": "echo1_delay.audio"
    },
    {
      "from": "echo1_delay.audio",
      "to": "echo1_gain.audio"
    },
    {
      "from": "echo1_gain.audio",
      "to": "mix.audio2"
    },
    {
      "from": "bell.audio",
      "to": "echo2_delay.audio"
    },
    {
      "from": "echo2_delay.audio",
      "to": "echo2_gain.audio"
    },
    {
      "from": "echo2_gain.audio",
      "to": "mix.audio3"
    },
    {
      "from": "bell.audio",
      "to": "echo3_delay.audio"
    },
    {
      "from": "echo3_delay.audio",
      "to": "echo3_gain.audio"
    },
    {
      "from": "echo3_gain.audio",
      "to": "mix.audio4"
    },
    {
      "from": "mix.audio",
      "to": "out.audio"
    }
  ],
  "probes": [
    "bell.audio",
    "mix.audio",
    "out.audio"
  ],
  "ui": {
    "nodes": {
      "note_freq": {"x": 60, "y": 60},
      "strike": {"x": 60, "y": 180},
      "bell": {"x": 280, "y": 120},
      "echo1_delay": {"x": 280, "y": 280},
      "echo1_gain": {"x": 420, "y": 280},
      "echo2_delay": {"x": 280, "y": 360},
      "echo2_gain": {"x": 420, "y": 360},
      "echo3_delay": {"x": 280, "y": 440},
      "echo3_gain": {"x": 420, "y": 440},
      "mix": {"x": 560, "y": 200},
      "out": {"x": 760, "y": 200}
    }
  }
}
