{
  "schema_version": "0.1",
  "name": "pasp_family_b3_d4_note_sweep",
  "sample_rate": 48000,
  "duration": 2.0,
  "block_size": 64,
  "inputs": {"midi_note": 60, "velocity_norm": 0.5},
  "blocks": [
    {
      "id": "panel",
      "type": "PanelMetricsTask",
      "params": {
        "panel": [
          {"midi_note": 59, "velocity_norm": 0.5, "velocity": 0.5},
          {"midi_note": 60, "velocity_norm": 0.5, "velocity": 0.5},
          {"midi_note": 61, "velocity_norm": 0.5, "velocity": 0.5},
          {"midi_note": 62, "velocity_norm": 0.5, "velocity": 0.5}
        ]
      }
    },
    {"id": "note", "type": "PASPNoteFamilyModel", "params": {"contact_model": "bidirectional", "num_modes": 32}},
    {"id": "out", "type": "Output", "params": {"peak_normalize_db": -1.0}}
  ],
  "connections": [
    {"from": "inputs.midi_note", "to": "note.midi_note"},
    {"from": "inputs.velocity_norm", "to": "note.velocity_norm"},
    {"from": "inputs.velocity_norm", "to": "note.velocity"},
    {"from": "note.audio", "to": "out.audio"}
  ],
  "probes": ["note.force", "note.audio", "note.string_displacement"]
}
