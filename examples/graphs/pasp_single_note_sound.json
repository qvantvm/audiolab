{
  "schema_version": "0.1",
  "name": "pasp_single_note_sound",
  "description": "Minimal PASP bidirectional single piano note (C4). Render-only — no CalibrationTask.",
  "sample_rate": 48000,
  "duration": 4.0,
  "block_size": 64,
  "inputs": {
    "midi_note": 60,
    "velocity": 100
  },
  "blocks": [
    {
      "id": "note",
      "type": "PASPNoteModel",
      "params": {
        "contact_model": "bidirectional",
        "hammer_mass_kg": 0.008,
        "felt_Q0": 5000000.0,
        "felt_p": 3.2,
        "felt_damping_Ns_m": 80.0,
        "felt_gap_m": 0.0,
        "hammer_rest_position_m": 0.008,
        "max_contact_force_N": 2000.0,
        "velocity_scale": 3.0,
        "velocity_exponent": 1.9,
        "string_length_m": 0.65,
        "string_tension_N": 700.0,
        "linear_density_kg_m": 0.006,
        "inharmonicity_B": 0.00035,
        "strike_position_ratio": 0.12,
        "num_modes": 48,
        "modal_loss_base": 0.12,
        "modal_loss_high": 0.4,
        "modal_gain": 1.0,
        "bridge_loss": 0.2,
        "soundboard_mix": 0.5,
        "oversample": 2,
        "output_gain": 1.0,
        "seed": 11
      }
    },
    {
      "id": "out",
      "type": "Output",
      "params": {
        "peak_normalize_db": -1.0
      }
    }
  ],
  "connections": [
    {"from": "inputs.midi_note", "to": "note.midi_note"},
    {"from": "inputs.velocity", "to": "note.velocity"},
    {"from": "note.audio", "to": "out.audio"}
  ],
  "probes": [
    "note.force",
    "note.compression",
    "note.hammer_velocity",
    "note.string_displacement",
    "note.audio",
    "out.audio"
  ],
  "ui": {
    "nodes": {
      "note": {"x": 280, "y": 160},
      "out": {"x": 520, "y": 160}
    }
  }
}
