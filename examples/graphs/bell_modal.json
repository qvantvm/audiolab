{
  "schema_version": "0.1",
  "name": "bell_modal",
  "sample_rate": 48000,
  "duration": 4.0,
  "block_size": 64,
  "inputs": {
    "midi_note": 76
  },
  "blocks": [
    {
      "id": "note_freq",
      "type": "MidiToFrequency",
      "params": {
        "a4": 440.0
      }
    },
    {
      "id": "strike",
      "type": "NoiseBurst",
      "params": {
        "amplitude": 0.85,
        "decay_ms": 6.0,
        "seed": 42
      }
    },
    {
      "id": "bell",
      "type": "ModalResonatorBank",
      "params": {
        "partials": [
          {"ratio": 0.56, "amplitude": 0.35, "decay_seconds": 4.0},
          {"ratio": 1.0, "amplitude": 1.0, "decay_seconds": 3.2},
          {"ratio": 1.41, "amplitude": 0.55, "decay_seconds": 2.4},
          {"ratio": 2.0, "amplitude": 0.4, "decay_seconds": 1.8},
          {"ratio": 2.65, "amplitude": 0.3, "decay_seconds": 1.3},
          {"ratio": 3.0, "amplitude": 0.22, "decay_seconds": 1.0},
          {"ratio": 4.1, "amplitude": 0.15, "decay_seconds": 0.7},
          {"ratio": 5.4, "amplitude": 0.1, "decay_seconds": 0.45}
        ]
      }
    },
    {
      "id": "out",
      "type": "Output",
      "params": {
        "peak_normalize_db": -1.0
      }
    }
  ],
  "connections": [
    {
      "from": "inputs.midi_note",
      "to": "note_freq.midi_note"
    },
    {
      "from": "note_freq.frequency",
      "to": "bell.frequency"
    },
    {
      "from": "strike.audio",
      "to": "bell.excitation"
    },
    {
      "from": "bell.audio",
      "to": "out.audio"
    }
  ],
  "probes": [
    "strike.audio",
    "bell.audio",
    "out.audio"
  ],
  "ui": {
    "nodes": {
      "note_freq": {
        "x": 80,
        "y": 80
      },
      "strike": {
        "x": 80,
        "y": 220
      },
      "bell": {
        "x": 380,
        "y": 140
      },
      "out": {
        "x": 680,
        "y": 140
      }
    }
  }
}
