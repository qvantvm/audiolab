{
  "schema_version": "0.1",
  "name": "pasp_performance_repeated_note",
  "sample_rate": 48000,
  "duration": 4.0,
  "block_size": 64,
  "inputs": {},
  "blocks": [
    {
      "id": "performance",
      "type": "PASPPerformanceModel",
      "params": {
        "contact_model": "bidirectional",
        "num_modes": 32,
        "use_register_defaults": true,
        "max_polyphony": 32,
        "shared_body": true,
        "sympathetic_enabled": false,
        "events": [
          {"time_s": 0.0, "type": "note_on", "note": 60, "velocity_norm": 0.6},
          {"time_s": 0.35, "type": "note_on", "note": 60, "velocity_norm": 0.55},
          {"time_s": 0.7, "type": "note_off", "note": 60},
          {"time_s": 1.5, "type": "note_off", "note": 60}
        ]
      }
    },
    {"id": "out", "type": "Output", "params": {"peak_normalize_db": -1.0}}
  ],
  "connections": [
    {"from": "performance.audio", "to": "out.audio"}
  ],
  "probes": ["performance.audio"]
}
